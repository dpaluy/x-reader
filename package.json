{
  "name": "x-reader",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "x-reader": "./src/cli.ts",
    "x-bookmarks": "./src/bookmarks.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "bookmarks": "bun run src/bookmarks.ts",
    "build": "bun build --compile src/cli.ts --outfile x-reader",
    "build:bookmarks": "bun build --compile src/bookmarks.ts --outfile x-bookmarks"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0"
  }
}
